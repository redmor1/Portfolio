---
import AboutMe from "@/components/AboutMe.astro";
import Contact from "@/components/Contact.astro";
import Project from "@/components/Project.astro";
import Layout from "@/layouts/Layout.astro";
import sentirsebienLogo from "@/assets/sentirse-bien/sentirse-bien-logo.svg";
import sentirsebienPhoto from "@/assets/sentirse-bien/sentirse-bien.png";
import eolonotasLogo from "@/assets/eolonotas/eolonotas-logo.svg";
import eolonotasPhoto from "@/assets/eolonotas/eolonotas.png";
import lafronteraLogo from "@/assets/la-frontera/la-frontera-logo.svg";
import lafronteraPhoto from "@/assets/la-frontera/la-frontera.png";
---

<Layout>
  <section
    class="mx-auto min-h-[75vh] max-w-6xl mb-24 text-center border-b-4 border-teal-950 py-8"
  >
    <div class="max-w-xl mx-auto">
      <h1
        class="font-display text-center font-bold w-full text-[7rem] xs:text-[8rem] sm:text-[10rem] sm:leading-32 xs:leading-32 leading-24 text-zinc-50 drop-shadow-2xl mb-8"
      >
        >Matias Zarate
      </h1>
      <div class="flex items-center justify-center mb-6">
        <h3
          class="text-teal-200 text-xl font-bold mr-4 underline-offset-2 font-display tracking-wider whitespace-nowrap"
        >
          Web Developer
        </h3>
        <span class="w-[15.70rem] bg-teal-200 inline-block h-1 align-middle"
        ></span>
      </div>
    </div>
    <div class="text-left max-w-sm mx-auto">
      <div class="text-left max-w-xl"></div>
      <h1 class="text-zinc-200 italic text-4xl font-bold my-4">
        Frontend-focused fullstack developer from Argentina
      </h1>
      <p class="text-zinc-400 mb-8 mt-4 text-md font-normal">
        I've got a solid foundation in building maintainable interfaces,
        reusable components, and responsive layouts using modern frontend tools.
        I value teamwork, clear communication, and keeping projects moving
        through practical, hands-on development.
      </p>
    </div>
  </section>
  <section id="projects" class="border-b-4 border-teal-950 max-w-6xl mx-auto">
    <h1
      class="font-display text-zinc-50 text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-center mb-24"
    >
      Projects
    </h1>
    <Project
      description={"Landing page for a football field. Made with Astro for ultra fast performance and SEO."}
      image={lafronteraPhoto}
      githubUrl="https://github.com/redmor1/La-Frontera"
      projectUrl="https://lafrontera.vercel.app/"
      tags={["Astro", "JavaScript", "Tailwind", "Vite"]}
      colors={{
        tagColor: "#91ee66",
        buttonColor: "#91ee66",
        buttonHoverColor: "#FFFF",
        buttonHoverTextColor: "#91ee66",
      }}
    >
      <img slot="logo" src={lafronteraLogo.src} class="h-36 mt-6" alt="logo" />
    </Project>
    <Project
      description={"Web application for a spa. It allows managing appointment bookings with availability control, service cart, user settings, and an admin panel. Includes authentication, different roles with separate views (client, professional, administrator), and real-time appointment handling logic."}
      image={sentirsebienPhoto}
      githubUrl="https://github.com/redmor1/Spa-SentirseBien"
      projectUrl="https://spa-sentirse-bien-eta.vercel.app/"
      tags={[
        "React",
        "Vite",
        "JavaScript",
        "Tailwind",
        "Node.js",
        "Express",
        "Prisma",
        "MySQL",
      ]}
      colors={{
        tagColor: "#FFA2B2",
        buttonColor: "#FFA2B2",
        buttonHoverColor: "#FFFF",
        buttonHoverTextColor: "#FFA2B2",
      }}
    >
      <img
        slot="logo"
        src={sentirsebienLogo.src}
        class="h-36 mt-2"
        alt="logo"
      />
    </Project>
    <Project
      description={"Mobile flashcard app inspired by Anki, built with React Native and local SQLite storage. Uses the SM-2 algorithm for efficient spaced repetition. Includes AI-powered card generation via OpenRouter and supports four card types: basic, write, image, and fill-in-the-blanks."}
      image={eolonotasPhoto}
      githubUrl="https://github.com/redmor1/eolonotas"
      projectUrl="https://github.com/redmor1/eolonotas"
      tags={["React Native", "Expo Go", "TypeScript", "SQLite"]}
      colors={{
        tagColor: "#8E5B9A",
        buttonColor: "#8E5B9A",
        buttonHoverColor: "#FFFF",
        buttonHoverTextColor: "#8E5B9A",
      }}
    >
      <img slot="logo" src={eolonotasLogo.src} class="h-40 mt-6" alt="logo" />
    </Project>
  </section>
  <AboutMe />
  <Contact />
</Layout>
