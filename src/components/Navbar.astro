---
import GitHubLogo from "@/components/icons/GitHubLogo.astro";
import LinkedInLogo from "@/components/icons/LinkedInLogo.astro";
---

<nav class="xs:flex justify-between max-w-6xl mx-auto mb-36 xs:pt-16 pt-12">
  <div class="xs:mb-0 mb-6 flex justify-center">
    <a
      href="https://drive.google.com/file/d/1z8CljwaCVsIDgR2FYhYHRr0-kyCFLKpW/view"
      class="font-display hover:bg-teal-600 text-zinc-100 text-2xl border-teal-600 border-4 rounded-md px-2 py-1 xs:block transition-colors ease-linear duration-200"
    >
      VIEW RESUME
    </a>
  </div>
  <div class="flex justify-between xs:mx-0 mx-auto w-72 max-w-xl items-center">
    <a
      href="https://github.com/redmor1"
      aria-label="Visit my GitHub profile"
      class="hover:bg-teal-600 text-zinc-100 p-1 rounded-xl transition-colors ease-in-out duration-200"
    >
      <GitHubLogo />
    </a>
    <a
      href="https://www.linkedin.com/in/matias-zarate-developer/"
      aria-label="Visit my LinkedIn profile"
      class="hover:bg-teal-600 text-zinc-100 py-1 px-1.5 rounded-xl transition-colors ease-in-out duration-200"
    >
      <LinkedInLogo />
    </a>

    <a
      href="#projects"
      class="text-zinc-100 font-bold text-2xl font-display rounded-md
            relative
            before:content-['']
            before:absolute
            before:-bottom-0.5
            before:left-0
            before:w-0
            before:h-0.75
            before:duration-200
            before:opacity-0
            before:transition-all
            before:bg-teal-500
            hover:before:w-full
            hover:before:opacity-100"
    >
      Projects
    </a>
    <a
      href="#contact"
      class="text-zinc-100 font-bold text-2xl font-display rounded-md
            relative
            before:content-['']
            before:absolute
            before:-bottom-0.5
            before:left-0
            before:w-0
            before:h-0.75
            before:duration-200
            before:opacity-0
            before:transition-all
            before:bg-teal-500
            hover:before:w-full
            hover:before:opacity-100"
    >
      Contact
    </a>
  </div>
</nav>
