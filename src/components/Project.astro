---
import GitHubLogo from "./icons/GitHubLogo.astro";
import LinkIcon from "./icons/LinkIcon.astro";
import type { ImageMetadata } from "astro";
import BlurPicture from "./BlurPicture.astro";

export interface ProjectColors {
  tagColor?: string;
  buttonColor?: string;
  buttonHoverColor?: string;
  buttonHoverTextColor?: string;
}

export interface Props {
  title?: string;
  description: string;
  image: ImageMetadata;
  githubUrl: string;
  projectUrl: string;
  tags?: string[];
  colors?: ProjectColors;
  showOverlay?: boolean;
  overlayText?: string;
}

const {
  title,
  description,
  image,
  githubUrl,
  projectUrl,
  tags = [],
  colors,
  showOverlay = false,
  overlayText = "UNDER CONSTRUCTION",
} = Astro.props;

// Default color scheme - portfolio colors
const defaultColors = {
  tagColor: "rgb(15 118 110)",
  buttonColor: "rgb(19 78 74)",
  buttonHoverColor: "rgb(244 244 245)",
  buttonHoverTextColor: "rgb(19 78 74)",
};

// Fallback to default colors if custom colors are not provided
const resolvedColors = {
  tagColor: colors?.tagColor || defaultColors.tagColor,
  buttonColor: colors?.buttonColor || defaultColors.buttonColor,
  buttonHoverColor: colors?.buttonHoverColor || defaultColors.buttonHoverColor,
  buttonHoverTextColor:
    colors?.buttonHoverTextColor || defaultColors.buttonHoverTextColor,
};
---

<div
  class="relative mx-auto bg-zinc-900 max-w-6xl mb-24 rounded-lg overflow-hidden
                flex flex-col md:min-h-112.5 lg:min-h-125 project-card-container group"
>
  {
    showOverlay && (
      <div class="project-overlay-wrapper absolute inset-0 z-50 pointer-events-none overflow-hidden flex items-center justify-center transition-opacity duration-500 lg:group-hover:opacity-15">
        <div class="project-overlay-text absolute bg-teal-400/10 border-y-2 border-teal-400/20 font-display font-black text-xl md:text-3xl uppercase w-[120%] shadow-2xl text-white rotate-[-10deg]">
          {/* Top slanted stripes border */}
          <div
            class="w-full h-2 md:h-3"
            style="background-image: repeating-linear-gradient(45deg, rgba(45, 212, 191, 0.2) 0, rgba(45, 212, 191, 0.2) 15px, transparent 15px, transparent 30px);"
          />

          {/* Repeating Text Center */}
          <div class="py-1 md:py-2 flex justify-center overflow-hidden whitespace-nowrap">
            {Array.from({ length: 20 }).map((_) => (
              <span class="mx-6 md:mx-10 shrink-0">{overlayText}</span>
            ))}
          </div>

          {/* Bottom slanted stripes border */}
          <div
            class="w-full h-2 md:h-3"
            style="background-image: repeating-linear-gradient(45deg, rgba(45, 212, 191, 0.2) 0, rgba(45, 212, 191, 0.2) 15px, transparent 15px, transparent 30px);"
          />
        </div>
      </div>
    )
  }

  {/* Text Content */}
  <div
    class="xs:px-16 px-8 py-8 text-left text-neutral-50
                  md:w-1/2 md:max-w-lg lg:max-w-xl md:relative md:z-10 h-fit"
  >
    <div class="flex gap-x-4 items-center">
      <a
        href={githubUrl}
        aria-label="Visit the project's GitHub repository"
        style={`--btn-bg: ${resolvedColors.buttonColor}; --btn-hover-bg: ${resolvedColors.buttonHoverColor}; --btn-hover-text: ${resolvedColors.buttonHoverTextColor};`}
        class="text-zinc-100 hover:bg-(--btn-hover-bg) hover:border-(--btn-hover-bg) hover:text-(--btn-hover-text) bg-(--btn-bg) border-2 border-(--btn-bg) py-0.5 px-1.5 rounded-xl font-bold underline-offset-2 font-display tracking-wider transition-colors duration-200"
      >
        <GitHubLogo />
      </a>
      <a
        href={projectUrl}
        aria-label="Visit the project's live demo"
        style={`--btn-bg: ${resolvedColors.buttonColor}; --btn-hover-bg: ${resolvedColors.buttonHoverColor}; --btn-hover-text: ${resolvedColors.buttonHoverTextColor};`}
        class="text-zinc-100 hover:bg-(--btn-hover-bg) hover:border-(--btn-hover-bg) hover:text-(--btn-hover-text) bg-(--btn-bg) border-2 border-(--btn-bg) py-0.5 px-0.5 rounded-xl font-bold underline-offset-2 font-display tracking-wider transition-colors duration-200"
      >
        <LinkIcon />
      </a>
    </div>
    <div class="justify-between flex flex-col">
      <div id="logo-description-container">
        {
          Astro.slots.has("logo") && (
            <div class="mb-4 mx-auto">
              <slot name="logo" />
            </div>
          )
        }

        {
          title && (
            <h1 class="text-5xl xs:text-6xl mb-4 mt-10 font-extrabold tracking-wide text-neutral-50 mx-auto">
              {title}
            </h1>
          )
        }
        <p class="mt-4 text-zinc-400 tracking-tight">{description}</p>
      </div>
      <div class="flex gap-x-4 flex-wrap mt-10 items-center">
        {
          tags &&
            tags.map((tag) => (
              <h3
                style={`color: ${resolvedColors.tagColor};`}
                class="text-2xl font-display uppercase tracking-wide"
              >
                {tag}
              </h3>
            ))
        }
      </div>
    </div>
  </div>

  {/* Image - Mobile: full width below text, Desktop: positioned to right */}
  <div
    class="w-full px-8 xs:px-16 pb-8
                  md:p-0 md:absolute md:right-0 md:top-1/2 md:transform md:-translate-y-1/2
                  md:w-[52%] md:h-auto rounded-2xl overflow-hidden"
  >
    <a href={projectUrl} class="block overflow-hidden rounded-2xl">
      <BlurPicture
        src={image}
        widths={[480, 800, 1280]}
        sizes="(min-width: 1024px) 33vw,
        (min-width: 768px) 50vw,
        100vw"
        formats={["avif", "webp"]}
        fallbackFormat="webp"
        alt={title || "Project image"}
        class="w-full h-auto shadow-[-8.0px_-1.0px_8.0px_rgba(0,0,0,0.38)]
                   md:max-h-100 lg:max-h-112.5 xl:max-h-125
                   object-contain md:ml-auto rounded-2xl"
        placeholder={true}
      />
    </a>
  </div>
</div>

<script>
  // Use IntersectionObserver to fade out the banner when the tape itself is in the center of the viewport
  const setupIntersectionObserver = () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          // Find the wrapper to apply the opacity class to
          const wrapper = entry.target.closest(".project-overlay-wrapper");
          if (wrapper) {
            if (entry.isIntersecting) {
              wrapper.classList.add("opacity-15");
            } else {
              wrapper.classList.remove("opacity-15");
            }
          }
        });
      },
      {
        // Trigger when the tape intersects the middle 30% of the viewport
        rootMargin: "-50% 0px -50% 0px",
      },
    );

    // Observe the tape itself rather than the huge card container
    const tapes = document.querySelectorAll(".project-overlay-text");
    tapes.forEach((tape) => observer.observe(tape));
  };

  // Run on mount
  document.addEventListener("DOMContentLoaded", setupIntersectionObserver);
  // Failsafe for fast rendering frameworks like Astro
  setupIntersectionObserver();
</script>
