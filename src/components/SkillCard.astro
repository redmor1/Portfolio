---
interface Props {
  title: string;
  skills: string[];
}

const { title, skills } = Astro.props
---

<div class="flex flex-col items-center h-full">
  <h1 class="text-zinc-200 font-bold text-4xl font-display mb-2">
    {title}
  </h1>
  <div class="max-w-40 xs:max-w-xs w-full flex flex-col flex-1">
    <span class="block h-1 w-full bg-teal-200 mb-3"></span>
    <div
      class="flex-1 bg-zinc-900 px-8 py-6 rounded-lg flex flex-col items-start gap-1"
    >
      {
        skills.map((skill) => (
          <p class="uppercase font-display text-xl text-zinc-400 whitespace-nowrap">
            {skill}
          </p>
        ))
      }
    </div>
  </div>
</div>
